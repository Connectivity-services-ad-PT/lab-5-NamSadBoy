    {
      "name": "12 - Create policy",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Staff office-hours access\",\n  \"description\": \"Allow active staff cards during office hours.\",\n  \"priority\": 100,\n  \"active\": true,\n  \"rules\": [\n    {\"ruleType\": \"ROLE\", \"allowedRoles\": [\"STAFF\", \"SECURITY\"]},\n    {\"ruleType\": \"TIME_WINDOW\", \"timezone\": \"Asia/Ho_Chi_Minh\", \"start\": \"06:00\", \"end\": \"22:00\"}\n  ]\n}"
        },
        "url": "{{baseUrl}}/policies"
      },
      "event": [
