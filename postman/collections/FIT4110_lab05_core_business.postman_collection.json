          {"key": "Idempotency-Key", "value": "lab03-detection-0001"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"requestId\": \"8cc9bb0d-ee85-41e5-a3fa-f4155c7286d8\",\n  \"detectionId\": \"4ec96900-37e0-47eb-9021-b95885c089d8\",\n  \"cameraId\": \"CAMERA-LOBBY-01\",\n  \"label\": \"UNKNOWN_PERSON\",\n  \"confidence\": 0.96,\n  \"occurredAt\": \"2026-05-19T08:21:00Z\"\n}"
        },
        "url": "{{baseUrl}}/policies/evaluate-detection"
      },
      "event": [
        {
          "listen": "test",
