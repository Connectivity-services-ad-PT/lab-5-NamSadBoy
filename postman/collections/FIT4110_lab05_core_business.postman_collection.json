        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"requestId\": \"475b7f6c-c10f-4038-8d51-ff4653b42de3\",\n  \"cardId\": \"bad\",\n  \"gateId\": \"GATE-A1\",\n  \"direction\": \"ENTRY\",\n  \"occurredAt\": \"2026-05-19T08:17:00Z\",\n  \"subject\": {\n    \"subjectId\": \"EMP-0009\",\n    \"role\": \"STAFF\",\n    \"cardStatus\": \"ACTIVE\",\n    \"zone\": \"ADMIN\"\n  }\n}"
        },
        "url": "{{baseUrl}}/policies/evaluate-access"
