          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create policy returns 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.test('Created policy is versioned', function () {",
              "  pm.expect(body.version).to.be.at.least(1);",
