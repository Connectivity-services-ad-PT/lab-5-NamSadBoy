              "pm.test('Invalid card id returns 422', function () { pm.response.to.have.status(422); });"
            ]
          }
        }
      ]
    },
    {
      "name": "09 - List alerts",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/alerts?status=OPEN&limit=20"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Alerts returns 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Alerts response has items and count', function () {",
              "  pm.expect(body.items).to.be.an('array');",
              "  pm.expect(body.count).to.be.a('number');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "10 - Sensor threshold creates alert",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Idempotency-Key", "value": "lab03-sensor-0001"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"requestId\": \"c95458d1-aa71-444f-82ad-a9d45337c12b\",\n  \"deviceId\": \"SENSOR-A101\",\n  \"metric\": \"TEMPERATURE\",\n  \"value\": 42.5,\n  \"unit\": \"CELSIUS\",\n  \"occurredAt\": \"2026-05-19T08:20:00Z\"\n}"
        },
        "url": "{{baseUrl}}/policies/evaluate-sensor"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Sensor evaluation returns 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('High temperature creates alert outcome', function () {",
              "  pm.expect(body.outcome).to.eql('ALERT');",
              "  pm.expect(body.reasonCode).to.eql('SENSOR_THRESHOLD_CRITICAL');",
              "  pm.expect(body.alertId).to.match(/^[0-9a-f-]{36}$/);",
              "});"
            ]
          }
        }
      ]
    },
