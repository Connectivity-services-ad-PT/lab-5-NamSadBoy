{
  "name": "fit4110-lab05-core-compose",
  "version": "1.0.0",
  "private": true,
  "description": "Docker Compose readiness for Core Business, PostgreSQL, and audit integration",
  "scripts": {
    "lint:openapi": "spectral lint contracts/*.yaml --ruleset campus-spectral.yaml",
    "test:compose": "newman run postman/collections/FIT4110_lab05_core_business.postman_collection.json -e postman/environments/FIT4110_lab05_core_local.postman_environment.json -r cli,junit,htmlextra --reporter-junit-export reports/newman-lab05-compose.xml --reporter-htmlextra-export reports/newman-lab05-compose.html",
    "test:integration": "newman run postman/collections/FIT4110_buoi06_core_integration.postman_collection.json -e postman/environments/FIT4110_lab05_core_local.postman_environment.json -r cli,junit,htmlextra --reporter-junit-export reports/newman-buoi06-integration.xml --reporter-htmlextra-export reports/newman-buoi06-integration.html",
    "test:mqtt": "node scripts/mqtt-smoke-test.mjs",
    "test:business": "node scripts/core-business-scenario-test.mjs",
    "test:all": "npm run test:compose && npm run test:integration && npm run test:mqtt && npm run test:business"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.13.1",
    "mqtt": "^5.10.4",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1"
  }
}
